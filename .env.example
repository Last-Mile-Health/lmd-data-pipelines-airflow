# ═══════════════════════════════════════════════════════════
# LMD Data Pipelines — Airflow Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy to .env and fill in values: cp .env.example .env
# IMPORTANT: Never hardcode secrets here — only secret NAMES
# (pointers to AWS Secrets Manager entries).

# ── AWS Credentials ──
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ── LMD Environment ──
# dev | test | prod
LMD_ENVIRONMENT=dev
LMD_PROJECT_CODE=lmd-dp-airflow-v1

# ═══════════════════════════════════════════════════════════
# AWS RESOURCES
# S3 buckets, DynamoDB, and Glue DB are created by CDK and
# named by convention: {LMD_PROJECT_CODE}-{LMD_ENVIRONMENT}-{resource}
# e.g. lmd-dp-airflow-v1-dev-raw, lmd-dp-airflow-v1-dev-processed
# ═══════════════════════════════════════════════════════════

# ── Redshift ──
REDSHIFT_SECRET_NAME=lmd-20-dev
# REDSHIFT_IAM_ROLE_ARN is created by CDK (lmd-dp-airflow-v1-{env}-redshift-spectrum-role)


RDS_OKR_SECRET_NAME=


# ═══════════════════════════════════════════════════════════
# SECRETS MANAGER REFERENCES
# These are the NAMES of secrets in AWS Secrets Manager.
# The actual credentials live in Secrets Manager, NOT here.
# Pipeline YAMLs reference these env var names with ${VAR}.
# ═══════════════════════════════════════════════════════════

# ── Kobo Toolbox ──
# Secret must contain: KOBO_API_TOKEN, KOBO_API_URL
KOBO_SECRET_NAME=lmd-dev-kobo-secrets

# ── DHIS2 ──
# Secret must contain: DHIS2_USERNAME, DHIS2_PASSWORD, DHIS2_BASE_URL
# (or DHIS2_TOKEN for token-based auth)
DHIS2_SECRET_NAME=lmd-dev-dhis2-secrets

# ═══════════════════════════════════════════════════════════
# SMTP — Email Notifications
# For AWS SES: use email-smtp.{region}.amazonaws.com
# Create SMTP credentials in SES console (different from IAM keys)
# ═══════════════════════════════════════════════════════════
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_MAIL_FROM=airflow@lmh.org

# ═══════════════════════════════════════════════════════════
# LOCAL DEVELOPMENT
# ═══════════════════════════════════════════════════════════

# Set to http://localstack:4566 when using docker compose --profile local
LOCALSTACK_ENDPOINT=
